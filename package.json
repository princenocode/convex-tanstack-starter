{
  "name": "convex-tanstack-starter",
  "description": "A feature-first, type-safe full-stack starter — TanStack Start + Convex + Better Auth, with the quality guard-rails wired up. Use it as a template.",
  "private": true,
  "license": "MIT",
  "author": "Prince NZANZU",
  "repository": {
    "type": "git",
    "url": "https://github.com/princenocode/convex-tanstack-starter.git"
  },
  "type": "module",
  "packageManager": "pnpm@10.8.1",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "bootstrap": "node scripts/bootstrap.mjs",
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "eslint . --cache --max-warnings=0",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.6.1",
    "@commitlint/config-conventional": "^19.6.0",
    "@convex-tanstack-starter/eslint-config": "workspace:*",
    "@convex-tanstack-starter/prettier-config": "workspace:*",
    "eslint": "^9.18.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.3.0",
    "prettier": "^3.4.2",
    "turbo": "^2.5.4",
    "typescript": "^5.7.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss",
      "unrs-resolver"
    ]
  }
}
