# Pin the registry explicitly and keep installs reproducible.
registry=https://registry.npmjs.org/

# Surface peer-dependency issues instead of silently auto-installing them.
auto-install-peers=true
strict-peer-dependencies=false

# Supply-chain hardening (docs/GUIDELINES.md §12.5): do not run install scripts
# from arbitrary transitive dependencies without review.
# Allowlist trusted build deps below as the project needs them.
# minimumReleaseAge slows down pulling in just-published (possibly compromised) versions.
minimum-release-age=1440
