# =============================================================================
# Environment variables — template. Copy to `.env.local` for local development.
#
# SECURITY (CONVENTIONS.md §12.2):
#   - Anything prefixed with VITE_ is bundled into the CLIENT and is PUBLIC.
#     Never put a secret behind a VITE_ prefix.
#   - Secrets (BETTER_AUTH_SECRET, OAuth client secrets, third-party API keys)
#     live on the CONVEX side only. Set them with `npx convex env set NAME value`,
#     never in this file or `.env.local`.
# =============================================================================

# --- Convex (created/populated by `npx convex dev`) --------------------------
# Deployment identifier written by the Convex CLI.
CONVEX_DEPLOYMENT=

# Public Convex deployment URLs (safe to expose in the client bundle).
VITE_CONVEX_URL=https://your-deployment.convex.cloud
VITE_CONVEX_SITE_URL=https://your-deployment.convex.site

# --- App ---------------------------------------------------------------------
# Public site URL used for auth redirects and absolute links.
VITE_SITE_URL=http://localhost:3000

# =============================================================================
# Convex-side secrets — DO NOT put these here. Set via the Convex CLI:
#
#   npx convex env set BETTER_AUTH_SECRET "$(openssl rand -base64 32)"
#   npx convex env set SITE_URL http://localhost:3000
#
# (SITE_URL is needed server-side by Better Auth in addition to VITE_SITE_URL.)
# =============================================================================
