{
  "$comment": "Convex compiles its functions with these settings. customConditions resolves Convex component source (e.g. @convex-dev/better-auth).",
  "compilerOptions": {
    "allowJs": true,
    "strict": true,
    "skipLibCheck": true,
    "module": "ESNext",
    "target": "ESNext",
    "lib": ["ES2023", "DOM"],
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "isolatedModules": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "customConditions": ["@convex-dev/component-source"]
  },
  "include": ["./**/*"],
  "exclude": ["./_generated"]
}
